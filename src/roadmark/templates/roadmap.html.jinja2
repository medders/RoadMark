<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ roadmap.front_matter.title }}</title>
  <style>{{ styles | safe }}</style>
</head>
<body>

  <!-- Header -->
  <header class="header">
    <h1 class="header__title">{{ roadmap.front_matter.title }}</h1>

    {% set fm = roadmap.front_matter %}
    {% if fm.owner or fm.team or fm.last_updated %}
    <div class="header__meta">
      {% if fm.owner %}
      <span class="header__meta-item">
        <strong>Owner:</strong>&nbsp;{{ fm.owner }}
      </span>
      {% endif %}
      {% if fm.team %}
      <span class="header__meta-item">
        {% if fm.team_link %}
        <strong>Team:</strong>&nbsp;<a href="{{ fm.team_link }}" target="_blank" rel="noopener">{{ fm.team }}</a>
        {% else %}
        <strong>Team:</strong>&nbsp;{{ fm.team }}
        {% endif %}
      </span>
      {% endif %}
      {% if fm.last_updated %}
      <span class="header__meta-item">
        <strong>Last updated:</strong>&nbsp;{{ fm.last_updated }}
      </span>
      {% endif %}
    </div>
    {% endif %}

    {% if fm.description %}
    <p class="header__description">{{ fm.description }}</p>
    {% endif %}
  </header>

  <!-- Board -->
  <main class="board">
    {% for column in roadmap.columns %}
    {% set col_class = "column--" + column.name | lower %}
    <section class="column {{ col_class }}{% if not column.themes %} column--empty{% endif %}">

      <div class="column__header">
        <span class="column__badge">{{ column.name }}</span>
        {% if column.themes %}
        <span class="column__count">{{ column.themes | length }} theme{% if column.themes | length != 1 %}s{% endif %}</span>
        {% endif %}
      </div>

      <div class="column__stack">
        {% for theme in column.themes %}
        <article class="card">

          <h3 class="card__title">
            {% if theme.link %}
            <a href="{{ theme.link }}" target="_blank" rel="noopener">{{ theme.name }}</a>
            {% else %}
            {{ theme.name }}
            {% endif %}
          </h3>

          {% if theme.objectives %}
          <div class="card__objectives">
            <div class="card__objectives-label">Objectives</div>
            <ul class="card__objectives-list">
              {% for obj in theme.objectives %}
              <li>{{ obj }}</li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}

          {% if theme.stakeholder or theme.component %}
          <div class="card__meta">
            {% if theme.stakeholder %}
            <span class="card__tag">
              <span class="card__tag-label">Stakeholder</span>
              {{ theme.stakeholder }}
            </span>
            {% endif %}
            {% if theme.component %}
            <span class="card__tag">
              <span class="card__tag-label">Component</span>
              {{ theme.component }}
            </span>
            {% endif %}
          </div>
          {% endif %}

          {% if theme.link %}
          <div class="card__link">
            <a href="{{ theme.link }}" target="_blank" rel="noopener">&#8599; View details</a>
          </div>
          {% endif %}

        </article>
        {% endfor %}
      </div>

    </section>
    {% endfor %}
  </main>

  <!-- Footer -->
  <footer class="footer">
    <span>Generated by <span class="footer__brand">RoadMark</span></span>
    {% if roadmap.front_matter.last_updated %}
    <span>Last updated: {{ roadmap.front_matter.last_updated }}</span>
    {% endif %}
  </footer>

</body>
</html>
